{
  "name": "sermon-multiplier2",
  "version": "0.1.21",
  "description": "설교 노트 기반 통합 목회자료 생성 플러그인 (Obsidian plugin + CLI + MCP server)",
  "license": "MIT",
  "type": "module",
  "bin": {
    "sermon-multiplier2": "./bin/sermon-multiplier.mjs"
  },
  "scripts": {
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production && node esbuild.cli.mjs production",
    "dev": "node esbuild.config.mjs",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "lint": "eslint .",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.15.17",
    "esbuild": "^0.21.5",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.4.0",
    "globals": "^17.6.0",
    "jiti": "^2.6.1",
    "obsidian": "latest",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.59.1"
  }
}
